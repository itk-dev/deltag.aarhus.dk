{# Template for Decision teaser extending base-card #}

{% extends 'themes/custom/hoeringsportal/templates/components/base-card.html.twig' %}

{# Deadline ("frist") and whether it has passed #}
{% set deadlinedate = decision_helper.getDeadlineDate(node) %}
{% set deadlinepassed = decision_helper.isDeadlinePassed(node) %}

{# Show a date splash on the card when the deadline is still active #}
{% block card_date %}
  {% if deadlinedate %}
    {% if deadlinepassed %}
      <div><strong>{{ 'Udløbet'|t }}</strong></div>
    {% else %}
      <div class="fw-semibold">{{ deadlinedate|format_date('hoeringsportal_day_only') }}</div>
      <div class="small">{{ deadlinedate|format_date('hoeringsportal_month_short') }}</div>
    {% endif %}
  {% endif %}
{% endblock %}

{# Show teaser description #}
{% block card_content %}
  {{ node.field_teaser.string|truncate(95, true, true) }}
{% endblock %}

{# Collect data for information lines on card, mirroring hearing/public meeting #}
{% set items = [] %}
{% if deadlinedate %}
  {% if deadlinepassed %}
    {% set items = items|merge([{icon: 'fa-calendar-day', value: 'Frist udløbet'|t}]) %}
  {% else %}
    {%
      set items = items|merge([
        {icon: 'fa-calendar-day', value: 'Frist'|t ~ ': ' ~ deadlinedate|format_date('hoeringsportal_date_long')|capitalize},
      ])
    %}
  {% endif %}
{% endif %}
{%
  set items = items|merge([
    {icon: 'fa-tags', value: content.field_area},
    {icon: 'fa-tag', value: content.field_type},
  ])
%}

{# Show card information #}
{% block card_type_information %}
  {% for item in items %}
    <div class="d-flex gap-3 justify-items-center {% if not loop.last %} border-bottom {% endif %}">
      <i class="fa-solid fa-fw fa-lg {{ item.icon }} text-decision"></i>
      <p class="small">{{ item.value }}</p>
    </div>
  {% endfor %}
{% endblock %}
