{% extends '@claro/node-edit-form.html.twig' %}

{% set secondary_items = [
  'advanced',
  'group_hide_hearing_replies',
  'group_information',
  'group_deskpro',
  'group_edoc',
  'group_getorganized',
  'group_contact',
  'group_more_info',
  'group_system_settings',
] %}

{% set footer_items = [
  'actions',
] %}

{% block main %}
  {{ form|without(secondary_items|merge(footer_items)) }}
{% endblock %}

{% block secondary %}
  {% for item in secondary_items %}
    {{ form[item] }}
  {% endfor %}
{% endblock %}

{% block footer %}
  {% for item in footer_items %}
    {{ form[item] }}
  {% endfor %}
{% endblock %}
